BASE="$HOME/dotfiles/zsh"
source $BASE/aliases.zsh
export ZSH=$HOME/.oh-my-zsh
#DISABLE_CORRECTION=”true”
unsetopt correct_all

#open tmux with utf-8 support instead of relying on local, got from dhruvsagar post
alias tmux="tmux -u"


LISTMAX=0 # ask to complete if top of list would scroll off screen

ZSH_THEME="robbyrussell"

plugins=(git)

source $ZSH/oh-my-zsh.sh
#zplug load
source $BASE/extras.zsh
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

export FZF_DEFAULT_COMMAND='(git ls-tree -r --name-only HEAD ||
   find * -name ".*" -prune -o -type f -print -o -type l -print) 2> /dev/null'
export ENHANCD_FILTER="fzf"
export PATH="$PATH:$HOME/.local/bin:/usr/local/opt/coreutils/libexec/gnubin"

unset LSCOLORS
export CLICOLOR=1
export CLICOLOR_FORCE=1

# Added by serverless binary installer
# export PATH="$HOME/.serverless/bin:$PATH"
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/tools
export PATH=$PATH:$ANDROID_HOME/tools/bin
export PATH=$PATH:$ANDROID_HOME/platform-tools

source /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# tabtab source for serverless package
# uninstall by removing these lines or running `tabtab uninstall serverless`
[[ -f /Users/vysakh/dermio-admin/node_modules/tabtab/.completions/serverless.zsh ]] && . /Users/vysakh/dermio-admin/node_modules/tabtab/.completions/serverless.zsh
# tabtab source for sls package
# uninstall by removing these lines or running `tabtab uninstall sls`
[[ -f /Users/vysakh/dermio-admin/node_modules/tabtab/.completions/sls.zsh ]] && . /Users/vysakh/dermio-admin/node_modules/tabtab/.completions/sls.zsh
